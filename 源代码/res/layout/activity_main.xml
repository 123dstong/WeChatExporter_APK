<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="微信聊天记录导出器"
        android:textSize="22sp"
        android:textColor="#07C160"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F5E9"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Root状态: "
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvRootStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测中..."
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="微信数据路径 (留空自动检测):"
        android:textSize="13sp"
        android:textColor="#666666"
        android:paddingBottom="4dp" />

    <EditText
        android:id="@+id/etPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="自动检测"
        android:textSize="13sp"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFF" />

    <Button
        android:id="@+id/btnExport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开始导出聊天记录"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="#07C160"
        android:padding="14dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="导出日志:"
        android:textSize="13sp"
        android:textColor="#666666"
        android:paddingBottom="4dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A2E"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF88"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:text="微信聊天记录导出器 v1.0\n─────────────────────\n功能: Root权限读取微信数据库\n      导出聊天记录为HTML/TXT\n─────────────────────\n准备就绪, 请点击上方按钮开始\n\n" />
    </ScrollView>
</LinearLayout>
